<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <RootNamespace>HonoraryParagons</RootNamespace>
        <Configurations>Debug;Release</Configurations>
        <Nullable>enable</Nullable>
        <AssemblyName>HonoraryParagons</AssemblyName>
        <LangVersion>latest</LangVersion>
        <Optimize>False</Optimize>
        <DebugType>embedded</DebugType>
    </PropertyGroup>
    <ItemGroup>
        <Content Include=".github\workflows\build.yml" />
    </ItemGroup>

    <Import Project="..\btd6.targets" />

    <ItemGroup>
        <Reference Include="Paragonomics">
            <HintPath>$(BloonsTD6)\Mods\Paragonomics.dll</HintPath>
        </Reference>
        <Reference Include="BuffsInShop">
            <HintPath>$(BloonsTD6)\Mods\BuffsInShop.dll</HintPath>
        </Reference>
    </ItemGroup>

</Project>
